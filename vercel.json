{
  "installCommand": "npm ci",
  "buildCommand": "npm run test:unit && ./scripts/validate.sh",
  "outputDirectory": "public",
  "framework": "hugo",
  "build": {
    "env": {
      "HUGO_VERSION": "0.154.5"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; manifest-src 'self'; upgrade-insecure-requests" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=()" }
      ]
    }
  ],
  "redirects": [
    { "source": "/projects/:path*", "destination": "/posts/", "permanent": true },
    { "source": "/garden/:path*", "destination": "/posts/", "permanent": true },
    { "source": "/now/:path*", "destination": "/about/", "permanent": true },
    { "source": "/books/:path*", "destination": "/about/", "permanent": true }
  ]
}
