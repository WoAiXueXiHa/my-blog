{
  "buildCommand": "hugo --gc --minify",
  "outputDirectory": "public",
  "framework": "hugo",
  "build": {
    "env": {
      "HUGO_VERSION": "0.154.5"
    }
  },
  "rewrites": [
    {
      "source": "/gitee-img/:path*",
      "destination": "https://gitee.com/binary-whispers/pic/raw/master/:path*"
    }
  ]
}
