{{- $items := slice -}}
{{- $posts := where site.RegularPages "Section" "posts" -}}
{{- range site.AllPages -}}
  {{- $include := and (not .IsHome) (not .Params.searchHidden) (ne .Layout "search") (ne .Layout "archives") (not (in (slice "taxonomy" "term") .Kind)) -}}
  {{- if and $include (eq .Section "topics") .Params.slug -}}
    {{- if eq (len (where $posts "Params.topic" .Params.slug)) 0 -}}{{- $include = false -}}{{- end -}}
  {{- end -}}
  {{- if $include -}}
    {{- $category := delimit (.Params.categories | default (slice .Params.topic)) " · " -}}
    {{- $items = $items | append (dict "title" .Title "content" (.Plain | truncate 500) "permalink" .RelPermalink "summary" (.Params.summary | default .Description | default .Summary | plainify | truncate 150) "section" .Section "topic" $category) -}}
  {{- end -}}
{{- end -}}
{{- $items | jsonify -}}
